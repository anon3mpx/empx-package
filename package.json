{
  "name": "empx-swap-sdk",
  "version": "2.0.0",
  "description": "Multi-chain DEX swap SDK — TypeScript-native, AI-agent-first, with dual on-chain + off-chain affiliate models",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "import": "./dist/wallet.js",
      "require": "./dist/wallet.js",
      "default": "./dist/wallet.js"
    },
    "./agent": {
      "types": "./dist/agent/schemas.d.ts",
      "import": "./dist/agent/schemas.js",
      "require": "./dist/agent/schemas.js",
      "default": "./dist/agent/schemas.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/tests/smoke.test.ts",
    "test:all": "tsx src/tests/run-all.ts",
    "test:fast": "npm run test && npm run test:unit",
    "test:smoke": "tsx src/tests/smoke.test.ts",
    "test:pathfind": "tsx src/tests/pathfind.test.ts",
    "test:affiliate": "tsx src/tests/affiliate.test.ts",
    "test:split": "tsx src/tests/split.test.ts",
    "test:unit": "tsx src/core/splitSolver.test.ts && tsx src/core/splitCalldata.test.ts && tsx src/core/feeTiers.test.ts && tsx src/core/affiliateTiers.test.ts && tsx src/wallet/x402Provider.test.ts"
  },
  "keywords": [
    "defi",
    "swap",
    "dex",
    "evm",
    "ai",
    "agent",
    "multichain",
    "typescript",
    "affiliate",
    "wallet",
    "arbitrum",
    "base",
    "pulsechain"
  ],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
